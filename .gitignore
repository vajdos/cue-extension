# Dependencies
node_modules/

# Build artifacts (regenerated via scripts/build-store-package.ps1)
dist/_stage/
dist/*.zip.bak

# OS / IDE cruft
desktop.ini
Thumbs.db
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Local-only / sensitive
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
.daily-log.md

# Claude Code session state
.claude/

# Test screenshots (regenerated per session, large)
assets/store/screenshots/*.png
!assets/store/screenshots/.gitkeep

# Founder tooling (not for public repo — contains personal phone + tester emails)
notify*.py
send_steve*.py
poll_twilio*.py

# Build artifacts (historical zips not needed in repo)
dist/*.zip
